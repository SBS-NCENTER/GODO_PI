# /etc/godo/webctl.env — operator-tunable env vars for godo-webctl.
# Defaults shown commented; uncomment + edit to override.

# Bind address. Default 127.0.0.1 = same-host only; set to 0.0.0.0 for studio LAN.
#GODO_WEBCTL_HOST=127.0.0.1

# HTTP port.
#GODO_WEBCTL_PORT=8080

# UDS socket of godo_tracker_rt. Must match the tracker's GODO_UDS_SOCKET.
#GODO_WEBCTL_UDS_SOCKET=/run/godo/ctl.sock

# Where /api/map/backup writes timestamped snapshots.
#GODO_WEBCTL_BACKUP_DIR=/var/lib/godo/map-backups

# Map .pgm path. MUST include the .pgm suffix and MUST match the tracker's
# GODO_AMCL_MAP_PATH; the .yaml sibling is derived by stripping .pgm.
#GODO_WEBCTL_MAP_PATH=/etc/godo/maps/studio_v1.pgm

# Per-syscall UDS timeouts. Worst-case wall-clock ≈ 3 × this value
# (connect + send + recv).
#GODO_WEBCTL_HEALTH_UDS_TIMEOUT_S=2.0
#GODO_WEBCTL_CALIBRATE_UDS_TIMEOUT_S=30.0

# --- PR-A frontend backend additions ----------------------------------------

# JWT signing secret. 32 random bytes auto-generated on first webctl boot
# if absent (mode 0600). Restarting webctl re-reads from disk; rotating
# the file invalidates ALL extant operator sessions.
#GODO_WEBCTL_JWT_SECRET_PATH=/var/lib/godo/auth/jwt_secret

# Operator credentials database (JSON). Lazy-seeded with admin
# `ncenter`/`ncenter` on first boot if absent. Use scripts/godo-webctl-passwd
# to add / change accounts.
#GODO_WEBCTL_USERS_FILE=/var/lib/godo/auth/users.json

# Path to the built Vite+Svelte SPA dist/. PR-A: leave UNSET to keep the
# legacy vanilla static page. PR-B will set this to e.g. /opt/godo-frontend/dist.
#GODO_WEBCTL_SPA_DIST=

# Loopback-only enforcement for /api/local/*. True (default) = trust the
# TCP peer IP; do NOT honour X-Forwarded-For. Only flip to false when a
# trusted reverse proxy fronts webctl AND the loopback gate is moved
# upstream.
#GODO_WEBCTL_CHROMIUM_LOOPBACK_ONLY=true
