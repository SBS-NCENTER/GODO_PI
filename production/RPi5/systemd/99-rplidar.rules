# issue#10 — stable /dev/rplidar symlink for the studio's RPLIDAR C1.
#
# Without this rule, the cp210x driver assigns ttyUSB0 / ttyUSB1 in
# enumeration order, which has caused two operator-side port swaps
# during HIL when an unrelated USB device was plugged at boot.
#
# Match by USB serial number (verified 2026-05-03 KST via live
# `udevadm info -a -n /dev/ttyUSB0` on news-pi01). The serial is
# stamped at SLAMTEC factory and is unique per LiDAR unit; replacing
# the LiDAR requires regenerating this file with the new serial.
#
# SYMLINK+= leaves the original /dev/ttyUSBN node intact (so existing
# tracker.toml entries that reference ttyUSB0 keep working as a
# fallback until the operator flips the runtime override). Tag is
# harmless: "systemd" lets udev annotations propagate cleanly.

ACTION=="add", SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", ATTRS{serial}=="2eca2bbb4d6eef1182aae9c2c169b110", SYMLINK+="rplidar", TAG+="systemd"
