# /run/godo/mapping/<instance>.env example
# webctl writes this file immediately before `systemctl start godo-mapping@active.service`.
# Operator never edits it directly.

# REQUIRED — name of the map being built. Must pass MAPPING_NAME_REGEX
# (^[A-Za-z0-9_()-][A-Za-z0-9._()\-,]{0,63}$). Webctl validates upstream.
MAP_NAME=control_room_v1

# REQUIRED — LiDAR USB device path. Webctl resolves this from the
# tracker-owned `[serial] lidar_port` key in
# /var/lib/godo/tracker.toml (canonical dotted name `serial.lidar_port`,
# verified at production/RPi5/src/core/config_schema.hpp:120). Default
# /dev/ttyUSB0 matches the tracker schema row default.
LIDAR_DEV=/dev/ttyUSB0

# OPTIONAL — Docker image tag. Defaults to godo-mapping:dev. Override
# via webctl's GODO_WEBCTL_MAPPING_IMAGE_TAG env-var on dev hosts that
# build with a different tag.
IMAGE_TAG=godo-mapping:dev
