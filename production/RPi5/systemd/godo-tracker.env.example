# /etc/godo/tracker.env — operator-tunable env vars for godo-tracker.
# Defaults shown commented; uncomment + edit to override.
#
# All keys are full-name `GODO_*` env vars consumed by
# `production/RPi5/src/core/config.cpp::Config::load`. They map 1:1 to
# Config fields and the SPA's /api/config schema. The full schema lives
# in `production/RPi5/src/core/config_schema.hpp` (CONFIG_SCHEMA[]).
#
# Tier order at load time: TOML (lowest) → env vars (middle) → CLI flags
# (highest). systemd unit's EnvironmentFile=-/etc/godo/tracker.env loads
# this layer; CLI flags would only apply if the unit's ExecStart line
# was edited (it isn't — ExecStart is just the binary path).

# --- MUST set on production hosts ----------------------------------------

# Active AMCL map path. Default `/etc/godo/maps/studio_v1.pgm` does not
# exist on news-pi01. Point this at the Track E (multi-map) `active.pgm`
# symlink that `godo-webctl` keeps current. The companion .yaml is
# resolved by extension swap.
GODO_AMCL_MAP_PATH=/var/lib/godo/maps/active.pgm

# Unreal Engine UDP destination. Default `192.168.0.0` is a TBD
# placeholder. Set to the studio's UE host IP (LAN or Tailscale).
#GODO_UE_HOST=192.168.0.10

# UE UDP port. Default 6666; freed-passthrough → 50003 path is unrelated.
#GODO_UE_PORT=6666

# --- Hardware overrides (rarely needed) ----------------------------------

# RPLIDAR C1 USB device path. Default `/dev/ttyUSB0`; if the operator's
# CP2102N adapter enumerates differently (e.g. via udev rule), set here.
#GODO_LIDAR_PORT=/dev/ttyUSB0
#GODO_LIDAR_BAUD=460800

# FreeD UART (PL011 UART0 via YL-128 → PlatformIO Wifi → SHOTOKU crane).
#GODO_FREED_PORT=/dev/ttyAMA0
#GODO_FREED_BAUD=38400

# --- Cold-path / RT scheduling (defaults are tuned, leave alone) ---------

# CPU 3 reserved for RT thread; isolcpus=3 in cmdline must agree.
#GODO_RT_CPU=3
#GODO_RT_PRIORITY=50

# Pidfile location — must live on local FS (tmpfs `/run/godo` is the
# project default). Don't change without updating CLAUDE.md §6.
#GODO_TRACKER_PIDFILE=/run/godo/godo-tracker.pid

# UDS socket for godo-webctl. Must match webctl's
# GODO_WEBCTL_UDS_SOCKET. Both default to /run/godo/ctl.sock.
#GODO_UDS_SOCKET=/run/godo/ctl.sock

# --- AMCL / map-frame parameters (operator only with eng review) ---------
# The /api/config schema is the SSOT. Use the SPA Config tab to edit
# these at runtime without tracker restart whenever possible.
#GODO_AMCL_ORIGIN_X_M=0.0
#GODO_AMCL_ORIGIN_Y_M=0.0
# Note: amcl.origin_yaw_deg was hard-removed in issue#28.1 (2026-W19);
# the active map's YAML origin[2] is now the SOLE source of truth.
#GODO_AMCL_PARTICLES_GLOBAL_N=10000
#GODO_AMCL_PARTICLES_LOCAL_N=2000
#GODO_AMCL_MAX_ITERS=200
#GODO_AMCL_SIGMA_HIT_M=0.05
# Track D-5 sigma annealing schedule for OneShot. Default chosen via
# news-pi01 sweep 2026-04-29; auto-minima tracking + patience-2 break
# means safe to add finer steps to the front. Comma-separated meters.
#GODO_AMCL_SIGMA_HIT_SCHEDULE_M=1.0,0.5,0.2,0.1,0.05
